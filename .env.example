# Commons — environment variables
# Copy this file to `.env` and adjust as needed:  cp .env.example .env

# ---- Database ----------------------------------------------------------------
# Prototype: local SQLite file (zero setup).
DATABASE_URL="file:./dev.db"
#
# Production: point at Postgres (e.g. Supabase / Neon / Vercel Postgres) and
# change `provider` to "postgresql" in prisma/schema.prisma, then run
# `npx prisma migrate deploy`.
# DATABASE_URL="postgresql://user:password@host:5432/commons?schema=public"

# ---- Auth --------------------------------------------------------------------
# Secret used to sign/verify session tokens. Generate a strong random value:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="dev-only-change-me-please-generate-a-real-secret"
