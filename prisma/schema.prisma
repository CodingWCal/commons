// Commons — Prisma schema
// Prototype uses SQLite for zero-setup local dev. For production, change
// `provider` to "postgresql" and point DATABASE_URL at your Postgres/Supabase
// connection string — no application code changes required.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  displayName  String
  passwordHash String
  avatarColor  String     @default("#3F7D5B")
  role         String       @default("member") // "member" | "admin"
  createdAt    DateTime     @default(now())
  sessions     Session[]
  messages     Message[]
  channels     Channel[]    @relation("ChannelCreatedBy")
  reactions    Reaction[]
  memberships  Membership[]
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Channel {
  id          String       @id @default(cuid())
  slug        String       @unique
  name        String
  description String?
  isDm        Boolean      @default(false)
  createdById String?
  createdBy   User?        @relation("ChannelCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime     @default(now())
  messages    Message[]
  members     Membership[]
}

model Membership {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, channelId])
  @@index([channelId])
}

model Message {
  id        Int        @id @default(autoincrement())
  body      String
  channelId String
  channel   Channel    @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
  deletedAt DateTime? // soft delete (TICKET-007)
  reactions Reaction[]

  @@index([channelId, id])
}

model Reaction {
  id        String   @id @default(cuid())
  emoji     String
  messageId Int
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}
